#!/usr/bin/env bash
set -euo pipefail

# post-tool-use — Auto-log vault file operations to _changelog.txt.
# Fired by PostToolUse hook via run-hook.cmd.
# Reads stdin JSON, determines if a vault file was written/edited/moved,
# and appends a timestamped entry to _changelog.txt.

# ── Resolve paths ────────────────────────────────────────────────────────────

PLUGIN_DATA="${CLAUDE_PLUGIN_DATA:-$HOME/.claude/cortex/plugin-data}"
CONFIG_FILE="$HOME/.claude/cortex/config.json"

# python3 is required to parse the stdin JSON payload. If it's missing, exit
# silently — the plugin still works for non-vault sessions but auto-changelog
# logging and re-embedding are unavailable on this platform.
if ! command -v python3 &>/dev/null; then
    printf '{}\n'
    exit 0
fi

# ── Helpers ──────────────────────────────────────────────────────────────────

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# ── Step 1: Read stdin JSON ──────────────────────────────────────────────────

INPUT=$(cat)

# ── Step 2: Extract tool_name and file path ──────────────────────────────────

PARSED="$(python3 -c "
import json, sys

data = json.loads(sys.argv[1])
tool_name = data.get('tool_name', '')

tool_input = data.get('tool_input', {})

# Determine which field holds the file path
if tool_name in ('Write', 'Edit'):
    file_path = tool_input.get('file_path', '')
elif tool_name == 'mcp__obsidian__move_note':
    file_path = tool_input.get('newPath', '')
else:
    file_path = tool_input.get('path', '')

print(tool_name)
print(file_path)
" "$INPUT" 2>/dev/null)" || exit 0

TOOL_NAME="$(echo "$PARSED" | sed -n '1p')"
FILE_PATH="$(echo "$PARSED" | sed -n '2p')"

if [[ -z "$TOOL_NAME" || -z "$FILE_PATH" ]]; then
    exit 0
fi

# ── Step 3: Resolve vault path ───────────────────────────────────────────────

CACHE_FILE="$PLUGIN_DATA/session-cache/vault-path.txt"
VAULT_PATH=""

if [[ -f "$CACHE_FILE" ]]; then
    VAULT_PATH="$(cat "$CACHE_FILE")"
fi

if [[ -z "$VAULT_PATH" && -f "$CONFIG_FILE" ]]; then
    VAULT_PATH="$(python3 -c "
import json
try:
    with open('$CONFIG_FILE') as f:
        print(json.load(f).get('vault_path', ''))
except Exception:
    pass
" 2>/dev/null)" || true
fi

if [[ -z "$VAULT_PATH" || ! -d "$VAULT_PATH" ]]; then
    exit 0
fi

# ── Step 4: Determine absolute path and check if inside vault ────────────────

ABS_PATH=""

case "$TOOL_NAME" in
    Write|Edit)
        # Write/Edit use absolute paths — compare directly
        ABS_PATH="$FILE_PATH"
        ;;
    mcp__obsidian__*)
        # Obsidian MCP tools use paths relative to vault root
        ABS_PATH="$VAULT_PATH/$FILE_PATH"
        ;;
    *)
        exit 0
        ;;
esac

# Check if inside vault (ABS_PATH must start with VAULT_PATH)
case "$ABS_PATH" in
    "$VAULT_PATH"/*)
        ;; # good — inside vault
    *)
        exit 0
        ;;
esac

# ── Step 5: Skip operational files ───────────────────────────────────────────

FILENAME="$(basename "$ABS_PATH")"

case "$FILENAME" in
    _changelog.txt|_pipeline_state.json|_session_manifest.md)
        exit 0
        ;;
esac

# ── Step 6: Infer action type ───────────────────────────────────────────────

ACTION=""
case "$TOOL_NAME" in
    Write|mcp__obsidian__write_note)
        ACTION="CREATED"
        ;;
    Edit|mcp__obsidian__patch_note|mcp__obsidian__update_frontmatter)
        ACTION="UPDATED"
        ;;
    mcp__obsidian__move_note)
        ACTION="MOVED"
        ;;
    mcp__obsidian__manage_tags)
        ACTION="TAGGED"
        ;;
    *)
        exit 0
        ;;
esac

# ── Step 7: Compute relative path ───────────────────────────────────────────

# Strip vault prefix + leading slash to get vault-relative path
REL_PATH="${ABS_PATH#"$VAULT_PATH"/}"
REL_DIR="$(dirname "$REL_PATH")"
if [[ "$REL_DIR" == "." ]]; then
    REL_DIR=""
else
    REL_DIR="$REL_DIR/"
fi

# ── Step 6b: Detect Knowledge Base writes for learning intake tagging ────────

KB_SOURCE=""
case "$REL_PATH" in
    "Knowledge Base/"*)
        # Check if this write was initiated by cortex-coach
        COACH_FLAG="$PLUGIN_DATA/session-cache/coach-active.flag"
        if [[ -f "$COACH_FLAG" ]]; then
            KB_SOURCE=" [source:coaching]"
        else
            KB_SOURCE=" [source:capture]"
        fi
        ;;
esac

# ── Step 8: Append to _changelog.txt via shared Node helper ─────────────────
# All changelog writers (MCP tools, this hook, reindex-one) go through
# lib/changelog-format.js so the line shape stays in lockstep. If `node` is
# missing, fall back to the inline format — slightly drift-prone but keeps
# the hook from going dark on systems without Node on PATH.

PLUGIN_ROOT_FOR_CLI="${CLAUDE_PLUGIN_ROOT:-${CURSOR_PLUGIN_ROOT:-}}"
APPEND_CLI="$PLUGIN_ROOT_FOR_CLI/mcp-servers/cortex-vault/bin/append-changelog-cli.js"
NOTE_TEXT="Auto-logged by hook${KB_SOURCE}"

if [[ -n "$PLUGIN_ROOT_FOR_CLI" && -f "$APPEND_CLI" ]] && command -v node &>/dev/null; then
    node "$APPEND_CLI" "$VAULT_PATH" "$ACTION" "$FILENAME" "$REL_DIR" "$NOTE_TEXT" --automated >/dev/null 2>&1 || true
else
    CHANGELOG="$VAULT_PATH/_changelog.txt"
    TIMESTAMP="$(date '+%Y-%m-%d %H:%M')"
    ENTRY="[$TIMESTAMP] $ACTION [auto] | FILE: $FILENAME | DEST: $REL_DIR | NOTE: $NOTE_TEXT"
    echo "$ENTRY" >> "$CHANGELOG"
fi

# ── Step 8b: Re-index .md file into semantic search (background, silent) ─────

if [[ "$FILENAME" == *.md ]]; then
    SKIP_REINDEX=0
    case "$REL_PATH" in
        .cortex/*|_Templates/*|Archives/*|.*)
            SKIP_REINDEX=1
            ;;
    esac
    if [[ "$SKIP_REINDEX" == "0" ]]; then
        PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-${CURSOR_PLUGIN_ROOT:-}}"
        REINDEX_BIN="$PLUGIN_ROOT/mcp-servers/cortex-vault/bin/reindex-one.js"
        if [[ -n "$PLUGIN_ROOT" && -f "$REINDEX_BIN" ]]; then
            (node "$REINDEX_BIN" "$VAULT_PATH" "$REL_PATH" >/dev/null 2>&1 &) || true
        fi
    fi
fi

# ── Step 9: Build additionalContext hint ────────────────────────────────────

if [[ "$ACTION" == "CREATED" ]]; then
    HINT="Auto-logged: $ACTION | $FILENAME | $REL_DIR. If this is a new file in a folder, update the folder's _MOC.md."
else
    HINT="Auto-logged: $ACTION | $FILENAME | $REL_DIR."
fi

CONTEXT="<cortex-changelog>$HINT</cortex-changelog>"
ESCAPED="$(escape_for_json "$CONTEXT")"

# ── Step 10: Output platform-appropriate JSON ───────────────────────────────

if [[ -n "${CURSOR_PLUGIN_ROOT:-}" ]]; then
    # Cursor
    printf '{"additional_context":"%s"}\n' "$ESCAPED"
elif [[ -n "${CLAUDE_PLUGIN_ROOT:-}" && -z "${COPILOT_CLI:-}" ]]; then
    # Claude Code
    printf '{"hookSpecificOutput":{"hookEventName":"PostToolUse","additionalContext":"%s"}}\n' "$ESCAPED"
else
    # Copilot CLI / default
    printf '{"additionalContext":"%s"}\n' "$ESCAPED"
fi
